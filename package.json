{
  "name": "pull-notifications",
  "displayName": "Pull Notifications",
  "description": "Notify when pulling latest changes in Git",
  "publisher": "Nithin-John",
  "version": "0.0.2",
  "engines": {
    "vscode": "^1.80.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nithinjohn22/pull-notifications.git"
  },
  "icon": "icon.png",
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pullNotifications.pull",
        "title": "Pull with Notification"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "tsc -p ./",
    "compile": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  }
}
